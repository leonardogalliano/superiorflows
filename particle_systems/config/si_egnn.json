{
    "data": {
        "data_path": "particle_systems/data/jbb_T1.0.xyz",
        "model_file": "particle_systems/models/jung_biroli_berthier.json",
        "temperature": 1.0
    },
    "training": {
        "nsteps": 100,
        "batch_size": 256,
        "seed": 42,
        "loss_type": "stochastic_interpolant",
        "log_freq": 10,
        "ckpt_path": "tmp/ckpt_particles_test"
    },
    "stochastic_interpolant": {
        "interpolant_scheduler": "jnp.sin(jnp.pi * t / 2)**2",
        "noise_scheduler": "0.05 * jnp.sqrt(2 * t * (1 - t))",
        "ot": {
            "enabled": true,
            "box_symmetry": true
        }
    },
    "optimizer": {
        "type": "adam",
        "lr_schedule": "optax.warmup_cosine_decay_schedule(init_value=0.0, peak_value=1e-3, warmup_steps=50, decay_steps=1000, end_value=0.0)"
    },
    "velocity": {
        "type": "egnn",
        "kwargs": {
            "hidden_nf": 32,
            "n_layers": 2,
            "recurrent": true
        }
    },
    "callbacks": {
        "ess": {
            "enabled": false
        },
        "boltzmann": {
            "enabled": true,
            "freq": 50,
            "samples": 200,
            "n_target_samples": 200
        },
        "tensorboard": {
            "enabled": true,
            "freq": 1,
            "log_dir": "tmp/tb_logs_test"
        }
    }
}